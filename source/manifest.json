{
  "manifest_version": 3,
  "name": "ADHD Blocker",
  "version": "1.0",
  "description": "No more distractions.",
  "permissions": ["storage","tabs","scripting","declarativeNetRequest"],
  "icons":{
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["block.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}